{
  "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "functionAppName": {
      "type": "string",
      "defaultValue": "engine-webflow-sync",
      "metadata": {
        "description": "Name of your Azure Function App"
      }
    },
    "functionKey": {
      "type": "securestring",
      "metadata": {
        "description": "Function key for authentication (get from Azure Portal > Function App > Functions > archive > Function Keys)"
      }
    }
  },
  "triggers": {
    "Recurrence": {
      "type": "Recurrence",
      "recurrence": {
        "frequency": "Day",
        "interval": 1,
        "timeZone": "UTC",
        "schedule": {
          "hours": [
            "2"
          ],
          "minutes": [
            0
          ]
        }
      }
    }
  },
  "actions": {
    "HTTP_Archive": {
      "type": "Http",
      "inputs": {
        "method": "POST",
        "uri": "https://@{parameters('functionAppName')}.azurewebsites.net/api/archive?code=@{parameters('functionKey')}",
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "daysThreshold": 90
        }
      },
      "runAfter": {}
    }
  },
  "outputs": {}
}
